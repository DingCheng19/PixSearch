# =========================
# Xcode関連ファイル
# =========================

# ビルド時に生成されるキャッシュ（各環境で異なるため不要）
DerivedData/
build/

# ユーザー固有の設定ファイル（個人環境依存のため共有不要）
xcuserdata/
*.xcuserdata/

# =========================
# Swift Package Manager
# =========================

# 依存ライブラリのビルドキャッシュ（再生成可能）
.build/

# Package.resolved はチーム運用では残すこともあるため、
# 今回はいったん無視しない
# Packages/ は通常Xcode管理下で不要
Packages/

# =========================
# macOS関連
# =========================

# Finderが自動生成するシステムファイル
.DS_Store

# =========================
# 機密情報
# =========================

# APIキーなどの機密情報
.env
Secrets.xcconfig